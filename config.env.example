# Copy this file to `config.env` and fill in your own values.
# `config.env` is gitignored — never commit real credentials.

# SMTP sender account
SENDER=your-email@example.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_SERVER=smtp.gmail.com
PORT=587

# Recipients (comma-separated)
CLIENTS=client1@example.com, client2@example.com
INTERNES=internal-team@example.com

# Whether to attach the Excel export to the email (true/false)
EXPORT=true
